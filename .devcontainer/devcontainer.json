{
  // Name, der in VS Code unten links im Container-Badge erscheint.
  "name": "Kmc.Eversports (PHP)",

  // Dockerfile statt "image" — entfernt die kaputte Yarn-apt-Quelle, bevor die Features draufkommen.
  "build": {
    "dockerfile": "Dockerfile"
  },

  // --privileged ist für Docker-in-Docker erforderlich (innerer Daemon braucht Kernel-Zugriff).
  "runArgs": ["--privileged"],

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  "postCreateCommand": "composer install && npm install",

  "customizations": {
    "vscode": {
      // Extensions, die VS Code im Container automatisch installiert:
      "extensions": [
        "bmewburn.vscode-intelephense-client", // PHP IntelliSense / Navigation / Refactoring
        "editorconfig.editorconfig",           // einheitliche Formatierung über .editorconfig
        "xdebug.php-debug",                    // Step-Debugging via Xdebug
        "recca0120.vscode-phpunit",            // Test-Explorer: einzelne Tests per Klick laufen lassen
        "ValeryanM.vscode-phpsab"              // phpcs/phpcbf: PSR-12-Squiggles + Format-on-Save über phpcs.xml.dist
      ],
      "settings": {
        "intelephense.stubs": [
          "apache", "bcmath", "bz2", "calendar", "Core", "ctype", "curl",
          "date", "dom", "exif", "fileinfo", "filter", "gd", "hash",
          "iconv", "intl", "json", "mbstring", "meta", "mysqli", "openssl",
          "pcntl", "pcre", "PDO", "pdo_mysql", "pdo_sqlite", "Phar",
          "posix", "readline", "Reflection", "session", "SimpleXML",
          "sodium", "SPL", "sqlite3", "standard", "tokenizer", "xml",
          "xmlreader", "xmlwriter", "zip", "zlib",
          "wordpress"
        ]
      }
    }
  }

}
