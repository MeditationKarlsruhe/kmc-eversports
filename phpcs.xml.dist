<?xml version="1.0"?>
<ruleset name="kmc-eversports">
    <description>Coding standard for Kmc.Eversports (PSR-12).</description>

    <file>src</file>
    <file>tests</file>
    <file>templates</file>
    <file>kmc-eversports.php</file>

    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PSR12">
        <exclude-pattern>tests/bootstrap.php</exclude-pattern>
    </rule>
</ruleset>
