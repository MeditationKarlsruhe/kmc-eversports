{
    "name": "kmc/eversports",
    "description": "Displays Eversports class schedules on the KMC WordPress site via the official GraphQL API.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Kmc\\Eversports\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kmc\\Eversports\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "phpcs",
        "cs:fix": "phpcbf"
    },
    "config": {
        "sort-packages": true
    }
}
