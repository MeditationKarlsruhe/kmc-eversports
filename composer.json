{
    "name": "kmc/eversports",
    "description": "Displays Eversports class schedules on the KMC WordPress site via the official GraphQL API.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kmc\\Eversports\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kmc\\Eversports\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
