{
    "name": "kmc/eversports",
    "description": "Displays Eversports class schedules on the KMC WordPress site via the official GraphQL API.",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "yahnis-elsts/plugin-update-checker": "^5.7"
    },
    "require-dev": {
        "brain/monkey": "^2.7",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.0",
        "spatie/phpunit-snapshot-assertions": "^5.4",
        "squizlabs/php_codesniffer": "^3.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Kmc\\Eversports\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kmc\\Eversports\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "phpcs",
        "cs:fix": "phpcbf",
        "mess": "phpmd src,tests,templates text phpmd.xml",
        "release": "bash bin/release.sh"
    },
    "config": {
        "sort-packages": true
    }
}
